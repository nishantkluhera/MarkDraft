# MarkDraft Environment Configuration
# Copy this file to .env and update the values as needed

# Server Configuration
NODE_ENV=development
PORT=3000
MAX_REQUEST_SIZE=10mb

# Frontend URL (used for CORS in production)
FRONTEND_URL=https://your-domain.com

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
# General requests per window (covers static assets and the live preview)
RATE_LIMIT_MAX=600
# Document conversions per window (Puppeteer/Word generation is expensive)
CONVERSION_RATE_LIMIT_MAX=10

# Logging Configuration
LOG_LEVEL=info

# Puppeteer / PDF generation
# Point this at a system Chromium when the bundled one can't run (e.g. Docker).
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
# Max PDFs rendered at once (protects memory); extra requests queue.
PDF_CONCURRENCY=2
# Max queued PDF requests before returning 503.
PDF_MAX_QUEUE=20

# Production optimizations
MAX_OLD_SPACE_SIZE=4096 