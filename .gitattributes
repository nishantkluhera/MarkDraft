# Normalize line endings. Store text files as LF in the repo and check them
# out as LF on every platform, so diffs never show CRLF/LF churn (important
# when collaborators are on Windows + macOS/Linux).
* text=auto eol=lf

# Binary assets — never apply EOL normalization.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff  binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.pdf  binary
*.docx binary
